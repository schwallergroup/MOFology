# Rule 7: Photocatalytic Capability (band gap 1.5-3.5 eV)
:MOFWithPhotocatalyticProperty a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            :MOF
            [ a owl:Restriction ;
              owl:onProperty :hasComputationalProperty ;
              owl:someValuesFrom [
                  a owl:Class ;
                  owl:intersectionOf (
                      :ComputationalProperty
                      [ a owl:Restriction ;
                        owl:onProperty :propertyName ;
                        owl:hasValue "Band gap"^^xsd:string
                      ]
                  )
              ]
            ]
        )
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty :hasCapability ;
        owl:someValuesFrom :PhotocatalyticCapability
    ] ;
    rdfs:comment "MOFs with band gap properties may have photocatalytic capability (value-based filtering can be done in queries)" .

# Rule 8: Luminescent Sensing Capability
:MOFWithLuminescence a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            :MOF
            [ a owl:Restriction ;
              owl:onProperty :hasPhysicalProperty ;
              owl:someValuesFrom [
                  a owl:Class ;
                  owl:intersectionOf (
                      :PhysicalProperty
                      [ a owl:Restriction ;
                        owl:onProperty :propertyName ;
                        owl:someValuesFrom [
                            a owl:Class ;
                            owl:oneOf (
                                "Luminescence"^^xsd:string
                                "Fluorescence"^^xsd:string
                                "Phosphorescence"^^xsd:string
                            )
                        ]
                      ]
                  )
              ]
            ]
        )
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty :hasCapability ;
        owl:someValuesFrom :LuminescentSensingCapability
    ] ;
    rdfs:comment "MOFs with luminescence properties have luminescent sensing capability" .

# Rule 9: Catalysis Capability
:MOFWithCatalysis a owl:Class ;
    owl:equivalentClass [
